{% extends 'base.html.twig' %}

{% block title %}Hello Appointments
{% endblock %}

{% block body %}
	{% for message in app.flashes('success') %}
		<div class="alert alert-success alert-dismissible fade show m-4" role="alert">
			{{ message }}

			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	{% endfor %}
	{% for type, messages in app.flashes %}
		{% for message in messages %}
			<div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
				{{ message }}

				<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
			</div>
		{% endfor %}
	{% endfor %}
	<div class="container mt-4">

		<div class="d-flex justify-content-between align-items-center mb-4">
			<h1>Appointments</h1>
			<div class="d-flex gap-2">

				<a href="{{ path('app_appointment_new') }}" class="btn btn-success">
					Add New Appointment
				</a>
				<a href="{{ path('app_dashboard') }}" class="btn btn-primary">
					Dashboard
				</a>
			</div>
		</div>
		<form method="get" action="{{ path('app_appointment_index') }}" class="input-group mb-3">
			<input type="search" name="a" class="form-control" placeholder="Search by patient or doctor..." value="{{ search }}"/>
			<button type="submit" class="btn btn-primary">Search</button>
		</form>

		<div class="table-responsive shadow-sm rounded">
			<table class="table table-hover align-middle mb-0">

				<thead class="table-primary">
					<tr>
					 
						<th class="text-nowrap">Patient</th>
						<th class="text-nowrap">Doctor</th>
						<th class="text-nowrap">Date</th>
						<th>Reason</th>
						<th class="text-nowrap">Status</th>
						<th class="text-nowrap">Actions</th>
					</tr>
				</thead>

				<tbody>
					{% for appointment in appointments %}
						<tr>

							 

							<td class="fw-semibold text-nowrap">
								{{ appointment.patient.firstName }}
								{{ appointment.patient.lastName }}
							</td>

							<td class="fw-semibold text-nowrap">
								{{ appointment.doctor.firstName }}
								{{ appointment.doctor.lastName }}
							</td>

							<td class="text-nowrap">
								{{ appointment.appointmentDate|date('Y-m-d H:i') }}
							</td>

							<td>
								<span class="d-inline-block text-truncate" style="max-width:250px;" title="{{ appointment.reason }}">
									{{ appointment.reason }}
								</span>
							</td>

							<td>
								{% if appointment.status == 'scheduled' %}
									<span class="badge bg-primary">
										{{ appointment.status }}
									</span>

								{% elseif appointment.status == 'completed' %}
									<span class="badge bg-success">
										{{ appointment.status }}
									</span>

								{% elseif appointment.status == 'cancelled' %}
									<span class="badge bg-danger">
										{{ appointment.status }}
									</span>

								{% else %}
									<span class="badge bg-secondary">
										{{ appointment.status }}
									</span>
								{% endif %}
							</td>

							<td>
								<div class="d-flex flex-nowrap gap-2 text-nowrap">

									<a href="{{ path('app_appointment_show', {'id': appointment.id}) }}" class="btn btn-sm btn-outline-primary" title="Show appointment">
										<i class="bi bi-eye"></i>
										<span class="d-none d-lg-inline">Show</span>
									</a>

									<a href="{{ path('app_appointment_edit', {'id': appointment.id}) }}" class="btn btn-sm btn-outline-secondary" title="Edit appointment">
										<i class="bi bi-pencil"></i>
										<span class="d-none d-lg-inline">Edit</span>
									</a>

									<form method="post" action="{{ path('app_appointment_delete', {'id': appointment.id}) }}" onsubmit="return confirm('Are you sure you want to delete this appointment?');">
										<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ appointment.id) }}">

										<button type="submit" class="btn btn-sm btn-outline-danger" title="Delete appointment">
											<i class="bi bi-trash"></i>
											<span class="d-none d-lg-inline">Delete</span>
										</button>
									</form>

								</div>
							</td>

						</tr>

					{% else %}
						<tr>
							<td colspan="7" class="text-center text-muted py-4">
								No appointments found.
							</td>
						</tr>
					{% endfor %}
				</tbody>

			</table>
		</div>
	</div>
	<div class="d-flex justify-content-center mt-4">
		{{ knp_pagination_render(appointments) }}
	</div>

{% endblock %}

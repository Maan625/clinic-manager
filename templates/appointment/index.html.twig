{% extends 'base.html.twig' %}

{% block title %}Hello Appointments
{% endblock %}

{% block body %}
	{% for message in app.flashes('success') %}
		<div class="alert alert-success alert-dismissible fade show m-4" role="alert">
			{{ message }}

			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	{% endfor %}
	<div class="container mt-4">

		<div class="d-flex justify-content-between align-items-center mb-4">
			<h1>Appointments</h1>
			<div class="d-flex gap-2">

				<a href="{{ path('app_appointment_new') }}" class="btn btn-success">
					Add New Appointment
				</a>
				<a href="{{ path('app_dashboard') }}" class="btn btn-primary">
					Dashboard
				</a>
			</div>
		</div>
        <form method="get" action="{{ path('app_appointment_index') }}" class="input-group mb-3">
            <input type="search" name="a" class="form-control" placeholder="Search by patient or doctor..." value="{{ search }}"/>
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
		<table class="table table-bordered table-hover">
			<thead>
				<tr>
					<th scope="col">ID</th>
					<th scope="col">Patient</th>
					<th scope="col">Doctor</th>
					<th scope="col">Date</th>
					<th scope="col">Reason</th>
					<th scope="col">Status</th>
					<th scope="col">Actions</th>
				</tr>
			</thead>
			<tbody>
				{% for appointment in appointments %}
					<tr>
						<td>{{ appointment.id }}</td>
						<td>{{ appointment.patient.firstname }}
							{{ appointment.patient.lastname }}</td>
						<td>{{ appointment.doctor.firstname }}
							{{ appointment.doctor.lastname }}</td>
						<td>{{ appointment.appointmentDate|date('Y-m-d H:i') }}</td>
						<td>{{ appointment.reason }}</td>
						<td>{{ appointment.status }}</td>
						<td>
                            <a href="{{ path('app_appointment_show', {'id': appointment.id}) }}" class="btn btn-sm btn-outline-primary">Show</a>
                            <a href="{{ path('app_appointment_edit', {'id': appointment.id}) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <form method="post" action="{{ path('app_appointment_delete', {'id': appointment.id}) }}" style="display: inline-block;" onsubmit="return confirm('Are you sure you want to delete this appointment?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ appointment.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="7">No appointments found.</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
    <div class="d-flex justify-content-center mt-4">
        {{ knp_pagination_render(appointments) }}
    </div>

{% endblock %}

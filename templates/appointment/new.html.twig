{% extends 'base.html.twig' %}

{% block title %}
    Add New Appointment | Clinic Manager
{% endblock %}

{% block body %}

<div class="container py-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">

        <div>
            <h1 class="mb-1">Add New Appointment</h1>

            <p class="text-muted mb-0">
                Fill in the information below to create a new appointment.
            </p>
        </div>

        <a
            href="{{ path('app_appointment_index') }}"
            class="btn btn-outline-primary"
        >
            <i class="bi bi-arrow-left"></i>
            Back to Appointments
        </a>

    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-9">

            <div class="card border-0 shadow-sm">

                <div class="card-body p-4 p-md-5">

                    <div class="d-flex align-items-center gap-2 mb-4">
                        <i class="bi bi-calendar-plus text-primary fs-4"></i>

                        <h2 class="h5 mb-0">
                            Appointment Information
                        </h2>
                    </div>

                    {{ form_start(form) }}

                    {{ form_errors(form) }}

                    <div class="row g-3">

                        <div class="col-12 col-md-6">
                            {{ form_row(form.patient) }}
                        </div>

                        <div class="col-12 col-md-6">
                            {{ form_row(form.doctor) }}
                        </div>

                        <div class="col-12 col-md-6">
                            {{ form_row(form.appointmentDate) }}
                        </div>

                        <div class="col-12 col-md-6">
                            {{ form_row(form.status) }}
                        </div>

                        <div class="col-12">
                            {{ form_row(form.reason) }}
                        </div>

                    </div>

                    <div class="d-flex flex-column-reverse flex-sm-row justify-content-end gap-2 mt-4">

                        <a
                            href="{{ path('app_appointment_index') }}"
                            class="btn btn-light"
                        >
                            Cancel
                        </a>

                        <button
                            type="submit"
                            class="btn btn-success px-4"
                        >
                            <i class="bi bi-check-lg"></i>
                            Save Appointment
                        </button>

                    </div>

                    {{ form_end(form) }}

                </div>

            </div>

        </div>
    </div>

</div>

{% endblock %}
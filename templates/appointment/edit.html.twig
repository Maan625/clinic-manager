{%- extends 'base.html.twig' -%}

{% block title %}Edit Appointment{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm border">
                <div class="card-body p-4 p-md-5">
                    <h2 class="h5 mb-4">Edit Appointment</h2>

                    {{ form_start(form) }}

                    <div class="row g-3">
                        <div class="col-md-6 text-primary">
                            {{ form_row(form.patient) }}
                        </div>

                        <div class="col-md-6 text-primary">
                            {{ form_row(form.doctor) }}
                        </div>

                        <div class="col-md-6 text-primary">
                            {{ form_row(form.appointmentDate) }}
                        </div>

                        <div class="col-md-6 text-primary">
                            {{ form_row(form.reason) }}
                        </div>

                        <div class="col-md-6 text-primary">
                            {{ form_row(form.status) }}
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a href="{{ path('app_appointment_index') }}" class="btn btn-light">
                            Cancel
                        </a>

                        <button type="submit" class="btn btn-success px-4">
                            Save Changes
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
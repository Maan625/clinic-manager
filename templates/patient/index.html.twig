{% extends 'base.html.twig' %}

{% block title %}Patients | Clinic Manager{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center m-4">
    <div>
        <h1>Patients List</h1>
        <p class="text-muted mb-4">Manage clinic patients.</p>
    </div>
    <div>
        <a href="#" class="btn btn-success">Add New Patient</a>
    </div>
</div>
<table class="table w-100 table-striped table-hover">
    <thead>
        <tr class="table-primary" >
            <th scope="col">First Name</th>
            <th scope="col">Last Name</th>
            <th scope="col">Email</th>
            <th scope="col">Phone</th>
            <th scope="col">Date of Birth</th>
            <th scope="col">Address</th>
            <th scope="col">Date Created</th>
            <th scope="col">Actions</th>
        </tr>
    </thead>
    <tbody class="">
        {% for patient in patients %}
            <tr>
                <td>{{ patient.firstname }}</td>
                <td>{{ patient.lastname }}</td>
                <td>{{ patient.email ? patient.email : '_' }}</td>
                <td>{{ patient.phone ? patient.phone : '_' }}</td>
                <td>{{ patient.birthDate ? patient.birthDate|date('Y-m-d') : '_' }}</td>
                <td>{{ patient.address ? patient.address : '_' }}</td>
                <td>{{ patient.createdAt|date('Y-m-d') }}</td>
                <td>
                    <a href="#" class="btn btn-sm  btn-outline-primary">Show</a>
                    <a href="#" class="btn btn-sm btn-outline-secondary">Edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">No patients found.</td>
            </tr>
        {% endfor %}
    </tbody>
</table>
    
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Patients | Clinic Manager{% endblock %}

{% block body %}
{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show m-4" role="alert">
        {{ message }}

        <button
            type="button"
            class="btn-close"
            data-bs-dismiss="alert"
            aria-label="Close"
        ></button>
    </div>
{% endfor %}
<div class="d-flex justify-content-between align-items-center m-4">
    <div>
        <h1>Patients List</h1>
        <p class="text-muted mb-4">Manage clinic patients.</p>
    </div>
    <div>
        <a href="{{ path('app_patient_new') }}" class="btn btn-success">Add New Patient</a>
    </div>
</div>
<div class="mx-4 mb-4">
    <form method="get" action="{{ path('app_patient_index') }}" class="input-group ">
        <input
            type="search"
            name="q"
            class="form-control"
            placeholder="Search by name or email..."
            value="{{ search }}"
        />
        <button type="submit" class="btn btn-primary">Search</button>
    </form>
</div>
<table class="table w-100 table-striped table-hover">
    <thead>
        <tr class="table-primary" >
            <th scope="col">First Name</th>
            <th scope="col">Last Name</th>
            <th scope="col">Email</th>
            <th scope="col">Phone</th>
            <th scope="col">Date of Birth</th>
            <th scope="col">Address</th>
            <th scope="col">Date Created</th>
            <th scope="col">Actions</th>
        </tr>
    </thead>
    <tbody class="">
        {% for patient in patients %}
            <tr>
                <td>{{ patient.firstname }}</td>
                <td>{{ patient.lastname }}</td>
                <td>{{ patient.email ? patient.email : '_' }}</td>
                <td>{{ patient.phone ? patient.phone : '_' }}</td>
                <td>{{ patient.birthDate ? patient.birthDate|date('Y-m-d') : '_' }}</td>
                <td>{{ patient.address ? patient.address : '_' }}</td>
                <td>{{ patient.createdAt|date('Y-m-d') }}</td>
                <td>
                    <a href="{{ path('app_patient_show', {'id': patient.id}) }}" class="btn btn-sm  btn-outline-primary">Show</a>
                    <a href="{{ path('app_patient_edit', {'id': patient.id}) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form method="post" action="{{ path('app_patient_delete', {'id': patient.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this patient?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete'~patient.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">No patients found.</td>
            </tr>
        {% endfor %}
    </tbody>
</table>
    
{% endblock %}

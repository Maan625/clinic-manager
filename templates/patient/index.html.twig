{% extends 'base.html.twig' %}

{% block title %}Patients | Clinic Manager
{% endblock %}

{% block body %}
	{% for message in app.flashes('success') %}
		<div class="alert alert-success alert-dismissible fade show m-4" role="alert">
			{{ message }}

			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	{% endfor %}
	<div class="container mt-4">

		<div class="d-flex justify-content-between align-items-center m-4">
			<div>
				<h1>Patients List</h1>
				<p class="text-muted mb-4">Manage clinic patients.</p>
			</div>
			<div class="d-flex gap-2">
				<div>
					<a href="{{ path('app_patient_new') }}" class="btn btn-success">Add New Patient</a>
				</div>
				<div>
					<a href="{{ path('app_dashboard') }}" class="btn btn-primary">Dashboard</a>
				</div>
			</div>
		</div>
		<div class="mx-4 mb-4">
			<form method="get" action="{{ path('app_patient_index') }}" class="input-group ">
				<input type="search" name="q" class="form-control" placeholder="Search by name or email..." value="{{ search }}"/>
				<button type="submit" class="btn btn-primary">Search</button>
			</form>
		</div>
		<div class="table-responsive shadow-sm rounded">
			<table class="table table-striped table-hover align-middle mb-0">

				<thead class="table-primary">
					<tr>
						<th scope="col" class="text-nowrap">First Name</th>
						<th scope="col" class="text-nowrap">Last Name</th>
						<th scope="col">Email</th>
						<th scope="col" class="text-nowrap">Phone</th>
						<th scope="col" class="text-nowrap">Date of Birth</th>
						<th scope="col">Address</th>
						<th scope="col" class="text-nowrap">Date Created</th>
						<th scope="col" class="text-nowrap">Actions</th>
					</tr>
				</thead>

				<tbody>
					{% for patient in patients %}
						<tr>
							<td class="fw-semibold text-nowrap">
								{{ patient.firstName }}
							</td>

							<td class="fw-semibold text-nowrap">
								{{ patient.lastName }}
							</td>

							<td>
								{{ patient.email ?: '_' }}
							</td>

							<td class="text-nowrap">
								{{ patient.phone ?: '_' }}
							</td>

							<td class="text-nowrap">
								{{ patient.birthDate ? patient.birthDate|date('Y-m-d') : '_' }}
							</td>

							<td>
								<span class="d-inline-block text-truncate" style="max-width: 220px;" title="{{ patient.address ?: '_' }}">
									{{ patient.address ?: '_' }}
								</span>
							</td>

							<td class="text-nowrap">
								{{ patient.createdAt|date('Y-m-d') }}
							</td>

							<td>
								<div class="d-flex flex-nowrap gap-2">

									<a href="{{ path('app_patient_show', {'id': patient.id}) }}" class="btn btn-sm btn-outline-primary" title="Show patient">
										<i class="bi bi-eye"></i>
										<span class="d-none d-lg-inline">Show</span>
									</a>

									<a href="{{ path('app_patient_edit', {'id': patient.id}) }}" class="btn btn-sm btn-outline-secondary" title="Edit patient">
										<i class="bi bi-pencil"></i>
										<span class="d-none d-lg-inline">Edit</span>
									</a>

									<form method="post" action="{{ path('app_patient_delete', {'id': patient.id}) }}" onsubmit="return confirm('Are you sure you want to delete this patient?');">
										<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ patient.id) }}">

										<button type="submit" class="btn btn-sm btn-outline-danger" title="Delete patient">
											<i class="bi bi-trash"></i>
											<span class="d-none d-lg-inline">Delete</span>
										</button>
									</form>

								</div>
							</td>
						</tr>

					{% else %}
						<tr>
							<td colspan="8" class="text-center text-muted py-4">
								No patients found.
							</td>
						</tr>
					{% endfor %}
				</tbody>

			</table>
		</div>
	</div>
	<div class="d-flex justify-content-center mt-4">
		{{ knp_pagination_render(patients) }}
	</div>

{% endblock %}

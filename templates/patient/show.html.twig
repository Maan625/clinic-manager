{% extends 'base.html.twig' %}

{% block title %}
	Patient Details
{% endblock %}

{% block body %}

	<div class="container py-5">

		<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">

			<div>
				<h1 class="mb-1">Patient Details</h1>

				<p class="text-muted mb-0">
					View detailed information about the patient.
				</p>
			</div>

			<div class="d-flex flex-wrap gap-2">

				<a href="{{ path('app_patient_index') }}" class="btn btn-outline-primary">
					<i class="bi bi-arrow-left"></i>
					Back to Patients
				</a>

				<a href="{{ path('app_patient_edit', {'id': patient.id}) }}" class="btn btn-success">
					<i class="bi bi-pencil"></i>
					Edit
				</a>

			</div>
		</div>

		<div class="card border-0 shadow-sm">

			<div class="card-header bg-primary text-white border-0 py-4">

				<div class="d-flex align-items-center gap-3">

					<div class="patient-avatar">
						<i class="bi bi-person-fill"></i>
					</div>

					<div>
						<h2 class="h4 mb-1">
							{{ patient.firstName }}
							{{ patient.lastName }}
						</h2>

						<p class="mb-0 opacity-75">
							Patient profile
						</p>
					</div>

				</div>
			</div>

			<div class="card-body p-4">

				<div class="row g-4">

					<div class="col-12 col-md-6">
						<div class="patient-detail-item">

							<div class="patient-detail-icon">
								<i class="bi bi-person"></i>
							</div>

							<div>
								<small class="text-muted d-block">
									First Name
								</small>

								<span class="fw-semibold">
									{{ patient.firstName }}
								</span>
							</div>

						</div>
					</div>

					<div class="col-12 col-md-6">
						<div class="patient-detail-item">

							<div class="patient-detail-icon">
								<i class="bi bi-person"></i>
							</div>

							<div>
								<small class="text-muted d-block">
									Last Name
								</small>

								<span class="fw-semibold">
									{{ patient.lastName }}
								</span>
							</div>

						</div>
					</div>

					<div class="col-12 col-md-6">
						<div class="patient-detail-item">

							<div class="patient-detail-icon">
								<i class="bi bi-envelope"></i>
							</div>

							<div>
								<small class="text-muted d-block">
									Email
								</small>

								{% if patient.email %}
									<a href="mailto:{{ patient.email }}" class="text-decoration-none text-break">
										{{ patient.email }}
									</a>
								{% else %}
									<span>_</span>
								{% endif %}
							</div>

						</div>
					</div>

					<div class="col-12 col-md-6">
						<div class="patient-detail-item">

							<div class="patient-detail-icon">
								<i class="bi bi-telephone"></i>
							</div>

							<div>
								<small class="text-muted d-block">
									Phone
								</small>

								{% if patient.phone %}
									<a href="tel:{{ patient.phone }}" class="text-decoration-none">
										{{ patient.phone }}
									</a>
								{% else %}
									<span>_</span>
								{% endif %}
							</div>

						</div>
					</div>

					<div class="col-12 col-md-6">
						<div class="patient-detail-item">

							<div class="patient-detail-icon">
								<i class="bi bi-calendar-heart"></i>
							</div>

							<div>
								<small class="text-muted d-block">
									Date of Birth
								</small>

								<span class="fw-semibold">
									{{ patient.birthDate ? patient.birthDate|date('Y-m-d') : '_' }}
								</span>
							</div>

						</div>
					</div>

					<div class="col-12 col-md-6">
						<div class="patient-detail-item">

							<div class="patient-detail-icon">
								<i class="bi bi-geo-alt"></i>
							</div>

							<div>
								<small class="text-muted d-block">
									Address
								</small>

								<span class="fw-semibold text-break">
									{{ patient.address ?: '_' }}
								</span>
							</div>

						</div>
					</div>

					<div class="col-12">
						<div class="patient-detail-item">

							<div class="patient-detail-icon">
								<i class="bi bi-calendar-check"></i>
							</div>

							<div>
								<small class="text-muted d-block">
									Date Created
								</small>

								<span class="fw-semibold">
									{{ patient.createdAt|date('Y-m-d') }}
								</span>
							</div>

						</div>
					</div>

				</div>
			</div>

		</div>

	</div>

{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}
	Edit Patient | Clinic Manager
{% endblock %}

{% block body %}

	<div class="container py-5">

		<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">

			<div>
				<h1 class="mb-1">Edit Patient</h1>

				<p class="text-muted mb-0">
					Update the patient's information.
				</p>
			</div>

			<a href="{{ path('app_patient_index') }}" class="btn btn-outline-primary">
				<i class="bi bi-arrow-left"></i>
				Back to Patients
			</a>

		</div>

		<div class="row justify-content-center">
			<div class="col-12 col-lg-9">

				<div class="card border-0 shadow-sm">
					<div class="card-body p-4 p-md-5">

						<div class="d-flex align-items-center gap-2 mb-4">
							<i class="bi bi-pencil-square text-primary fs-4"></i>

							<h2 class="h5 mb-0">
								Patient Information
							</h2>
						</div>

						{{ form_start(form) }}

						{{ form_errors(form) }}

						<div class="row g-3">

							<div class="col-12 col-md-6">
								{{ form_row(form.firstName) }}
							</div>

							<div class="col-12 col-md-6">
								{{ form_row(form.lastName) }}
							</div>

							<div class="col-12 col-md-6">
								{{ form_row(form.email) }}
							</div>

							<div class="col-12 col-md-6">
								{{ form_row(form.phone) }}
							</div>

							<div class="col-12 col-md-6">
								{{ form_row(form.birthDate) }}
							</div>

							<div class="col-12">
								{{ form_row(form.address) }}
							</div>

						</div>

						<div class="d-flex flex-column-reverse flex-sm-row justify-content-end gap-2 mt-4">

							<a href="{{ path('app_patient_index') }}" class="btn btn-light">
								Cancel
							</a>

							<button type="submit" class="btn btn-primary px-4">
								<i class="bi bi-check-lg"></i>
								Update Patient
							</button>

						</div>

						{{ form_end(form) }}

					</div>
				</div>

			</div>
		</div>

	</div>

{% endblock %}

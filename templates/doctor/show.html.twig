{%- extends 'base.html.twig' -%}

{% block title %}Doctors Details
{% endblock %}

{% block body %}

	<div class="container py-5">
		<div class="d-flex justify-content-between align-items-center mb-4">
			<div>
				<h1 class="mb-1">Doctor Details</h1>
				<p class="text-muted mb-0">
					View detailed information about the doctor.
				</p>
			</div>
			<div>

				<a href="{{ path('app_doctor_index') }}" class="btn btn-primary">
					Back to Doctors
				</a>
				<a href="{{ path('app_doctor_edit', {'id': doctor.id}) }}" class="btn btn-success m-4">Edit</a>
			</div>
		</div>
		<div class="card border-0 shadow-sm">
			<div class="card-body">
				<table class="table mb-0">
					<tbody>
						<tr>
							<th scope="row">First Name</th>
							<td>{{ doctor.firstname }}</td>
						</tr>
						<tr>
							<th scope="row">Last Name</th>
							<td>{{ doctor.lastname }}</td>
						</tr>
						<tr>
							<th scope="row">Email</th>
							<td>{{ doctor.email ? doctor.email : '_' }}</td>
						</tr>
						<tr>
							<th scope="row">Phone</th>
							<td>{{ doctor.phone ? doctor.phone : '_' }}</td>
						</tr>
						<tr>
							<th scope="row">Specialty</th>
							<td>{{ doctor.specialty ? doctor.specialty : '_' }}</td>
						</tr>
						<tr>
							<th scope="row">Date Created</th>
							<td>{{ doctor.createdAt|date('Y-m-d') }}</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>
	</div>

{% endblock %}

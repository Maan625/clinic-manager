{% extends 'base.html.twig' %}

{% block title %}
    Doctor Details
{% endblock %}

{% block body %}

<div class="container py-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">

        <div>
            <h1 class="mb-1">Doctor Details</h1>

            <p class="text-muted mb-0">
                View detailed information about the doctor.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">

            <a
                href="{{ path('app_doctor_index') }}"
                class="btn btn-outline-primary"
            >
                <i class="bi bi-arrow-left"></i>
                Back to Doctors
            </a>

            <a
                href="{{ path('app_doctor_edit', {'id': doctor.id}) }}"
                class="btn btn-success"
            >
                <i class="bi bi-pencil"></i>
                Edit
            </a>

        </div>
    </div>

    <div class="card border-0 shadow-sm">

        <div class="card-header bg-primary text-white border-0 py-4">

            <div class="d-flex align-items-center gap-3">

                <div class="doctor-avatar">
                    <i class="bi bi-person-badge-fill"></i>
                </div>

                <div>
                    <h2 class="h4 mb-1">
                        Dr. {{ doctor.firstName }} {{ doctor.lastName }}
                    </h2>

                    <p class="mb-0 opacity-75">
                        {{ doctor.specialty ?: 'Specialty not specified' }}
                    </p>
                </div>

            </div>
        </div>

        <div class="card-body p-4">

            <div class="row g-4">

                <div class="col-12 col-md-6">

                    <div class="doctor-detail-item">
                        <div class="doctor-detail-icon">
                            <i class="bi bi-person"></i>
                        </div>

                        <div>
                            <small class="text-muted d-block">
                                First Name
                            </small>

                            <span class="fw-semibold">
                                {{ doctor.firstName }}
                            </span>
                        </div>
                    </div>

                </div>

                <div class="col-12 col-md-6">

                    <div class="doctor-detail-item">
                        <div class="doctor-detail-icon">
                            <i class="bi bi-person"></i>
                        </div>

                        <div>
                            <small class="text-muted d-block">
                                Last Name
                            </small>

                            <span class="fw-semibold">
                                {{ doctor.lastName }}
                            </span>
                        </div>
                    </div>

                </div>

                <div class="col-12 col-md-6">

                    <div class="doctor-detail-item">
                        <div class="doctor-detail-icon">
                            <i class="bi bi-envelope"></i>
                        </div>

                        <div>
                            <small class="text-muted d-block">
                                Email
                            </small>

                            {% if doctor.email %}
                                <a
                                    href="mailto:{{ doctor.email }}"
                                    class="text-decoration-none text-break"
                                >
                                    {{ doctor.email }}
                                </a>
                            {% else %}
                                <span>_</span>
                            {% endif %}
                        </div>
                    </div>

                </div>

                <div class="col-12 col-md-6">

                    <div class="doctor-detail-item">
                        <div class="doctor-detail-icon">
                            <i class="bi bi-telephone"></i>
                        </div>

                        <div>
                            <small class="text-muted d-block">
                                Phone
                            </small>

                            {% if doctor.phone %}
                                <a
                                    href="tel:{{ doctor.phone }}"
                                    class="text-decoration-none"
                                >
                                    {{ doctor.phone }}
                                </a>
                            {% else %}
                                <span>_</span>
                            {% endif %}
                        </div>
                    </div>

                </div>

                <div class="col-12 col-md-6">

                    <div class="doctor-detail-item">
                        <div class="doctor-detail-icon">
                            <i class="bi bi-heart-pulse"></i>
                        </div>

                        <div>
                            <small class="text-muted d-block">
                                Specialty
                            </small>

                            <span class="fw-semibold">
                                {{ doctor.specialty ?: '_' }}
                            </span>
                        </div>
                    </div>

                </div>

                <div class="col-12 col-md-6">

                    <div class="doctor-detail-item">
                        <div class="doctor-detail-icon">
                            <i class="bi bi-calendar-check"></i>
                        </div>

                        <div>
                            <small class="text-muted d-block">
                                Date Created
                            </small>

                            <span class="fw-semibold">
                                {{ doctor.createdAt|date('Y-m-d') }}
                            </span>
                        </div>
                    </div>

                </div>

            </div>
        </div>

    </div>

</div>

{% endblock %}
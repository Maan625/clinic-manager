{% extends 'base.html.twig' %}

{% block title %}Add New Doctor | Clinic Manager
{% endblock %}

{% block body %}
	<div class="d-flex justify-content-between align-items-center m-4">
		<div>
			<h1>Add New Doctor</h1>
			<p class="text-muted mb-4">Fill in the details to add a new doctor.</p>
		</div>
		<div>
			<a href="{{ path('app_doctor_index') }}" class="btn btn-primary">Back to Doctors</a>
		</div>
	</div>

	<div class="row justify-content-center">
		<div class="col-lg-9">
			<div class="card border-0 shadow-sm border">
				<div class="card-body p-4 p-md-5">
					<h2 class="h5 mb-4">Doctor Information</h2>

					{{ form_start(form) }}

					<div class="row g-3">
						<div class="col-md-6 text-primary">
							{{ form_row(form.firstName) }}
						</div>

						<div class="col-md-6 text-primary">
							{{ form_row(form.lastName) }}
						</div>

						<div class="col-md-6 text-primary">
							{{ form_row(form.email) }}
						</div>

						<div class="col-md-6 text-primary">
							{{ form_row(form.phone) }}
						</div>

						<div class="col-md-6 text-primary">
							{{ form_row(form.specialty ) }}
						</div>
						
					</div>
					<div class="d-flex justify-content-end gap-2 mt-4">
						<a href="{{ path('app_patient_index') }}" class="btn btn-light">
							Cancel
						</a>
						<button type="submit" class="btn btn-primary">
							Save Doctor
						</button>
					</div>

					{{ form_end(form) }}
				</div>
			</div>
		</div>
	</div>
</div>{% endblock %}

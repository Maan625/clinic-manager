{% extends 'base.html.twig' %}

{% block title %}Doctors | Clinic Manager
{% endblock %}

{% block body %}
	{% for message in app.flashes('success') %}
		<div class="alert alert-success alert-dismissible fade show m-4" role="alert">
			{{ message }}

			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	{% endfor %}
	<div class="d-flex justify-content-between align-items-center m-4">
		<div>
			<h1>Doctors List</h1>
			<p class="text-muted mb-4">Manage clinic doctors.</p>
		</div>
		<div class="d-flex gap-2">
			<div>
				<a href="{{ path('app_doctor_new') }}" class="btn btn-success">Add New Doctor</a>
			</div>
			<div>
				<a href="{{ path('app_dashboard') }}" class="btn btn-primary">Dashboard</a>
			</div>
		</div>
	</div>
	{# <div class="mx-4 mb-4">
		    <form method="get" action="{{ path('app_doctor_index') }}" class="input-group ">
		        <input
		            type="search"
		            name="q"
		            class="form-control"
		            placeholder="Search by name or email..."
		            value="{{ app.request.get('q') }}"
		        />
		        <button type="submit" class="btn btn-primary">Search</button>
		    </form>
		</div> #}
	<table class="table w-100 table-striped table-hover">
		<thead>
			<tr class="table-primary">
				<th scope="col">First Name</th>
				<th scope="col">Last Name</th>
				<th scope="col">Email</th>
				<th scope="col">Phone</th>
				<th scope="col">Specialty</th>
				<th scope="col">Date Created</th>

			</tr>
		</thead>
		<tbody>
			{% for doctor in doctors %}
				<tr>
					<td>{{ doctor.firstname }}</td>
					<td>{{ doctor.lastname }}</td>
					<td>{{ doctor.email ? doctor.email : '_' }}</td>
					<td>{{ doctor.phone ? doctor.phone : '_' }}</td>
					<td>{{ doctor.specialty ? doctor.specialty : '_' }}</td>
					<td>{{ doctor.createdAt|date('Y-m-d') }}</td>
					<td>
						<a href="{{ path('app_doctor_show', {'id': doctor.id}) }}" class="btn btn-sm  btn-outline-primary">Show</a>
						<a href="{{ path('app_doctor_edit', {'id': doctor.id}) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
						<form method="post" action="{{ path('app_doctor_delete', {'id': doctor.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this doctor?');">
							<input type="hidden" name="_token" value="{{ csrf_token('delete'~doctor.id) }}">
							<button class="btn btn-sm btn-outline-danger">Delete</button>
						</form>
					</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
	{# <div class="d-flex justify-content-center mt-4">
		    {{ knp_pagination_render(doctors) }}
		</div>   #}
{% endblock %}

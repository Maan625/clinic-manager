{% extends 'base.html.twig' %}

{% block title %}Doctors | Clinic Manager
{% endblock %}

{% block body %}
	{% for message in app.flashes('success') %}
		<div class="alert alert-success alert-dismissible fade show m-4" role="alert">
			{{ message }}

			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	{% endfor %}
	<div class="container mt-4">

	<div class="d-flex justify-content-between align-items-center m-4">
		<div>
			<h1>Doctors List</h1>
			<p class="text-muted mb-4">Manage clinic doctors.</p>
		</div>
		<div class="d-flex gap-2">
			<div>
				<a href="{{ path('app_doctor_new') }}" class="btn btn-success">Add New Doctor</a>
			</div>
			<div>
				<a href="{{ path('app_dashboard') }}" class="btn btn-primary">Dashboard</a>
			</div>
		</div>
	</div>
	<div class="mx-4 mb-4">
		<form method="get" action="{{ path('app_doctor_index') }}" class="input-group ">
			<input type="search" name="d" class="form-control" placeholder="Search by name or email or specialty..." value="{{ search }}"/>
			<button type="submit" class="btn btn-primary">Search</button>
		</form>
	</div>
	<div class="table-responsive shadow-sm rounded">
		<table class="table table-striped table-hover align-middle mb-0">

			<thead class="table-primary">
				<tr>
					<th scope="col" class="text-nowrap">First Name</th>
					<th scope="col" class="text-nowrap">Last Name</th>
					<th scope="col">Email</th>
					<th scope="col" class="text-nowrap">Phone</th>
					<th scope="col">Specialty</th>
					<th scope="col" class="text-nowrap">Date Created</th>
					<th scope="col" class="text-nowrap">Actions</th>
				</tr>
			</thead>

			<tbody>
				{% for doctor in doctors %}
					<tr>
						<td class="fw-semibold text-nowrap">
							{{ doctor.firstName }}
						</td>

						<td class="fw-semibold text-nowrap">
							{{ doctor.lastName }}
						</td>

						<td>
							{{ doctor.email ?: '_' }}
						</td>

						<td class="text-nowrap">
							{{ doctor.phone ?: '_' }}
						</td>

						<td>
							{{ doctor.specialty ?: '_' }}
						</td>

						<td class="text-nowrap">
							{{ doctor.createdAt|date('Y-m-d') }}
						</td>

						<td>
							<div class="d-flex flex-nowrap gap-2">

								<a href="{{ path('app_doctor_show', {'id': doctor.id}) }}" class="btn btn-sm btn-outline-primary">
									<i class="bi bi-eye"></i>
									<span class="d-none d-lg-inline">Show</span>
								</a>

								<a href="{{ path('app_doctor_edit', {'id': doctor.id}) }}" class="btn btn-sm btn-outline-secondary">
									<i class="bi bi-pencil"></i>
									<span class="d-none d-lg-inline">Edit</span>
								</a>

								<form method="post" action="{{ path('app_doctor_delete', {'id': doctor.id}) }}" onsubmit="return confirm('Are you sure you want to delete this doctor?');">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ doctor.id) }}">

									<button type="submit" class="btn btn-sm btn-outline-danger">
										<i class="bi bi-trash"></i>
										<span class="d-none d-lg-inline">Delete</span>
									</button>
								</form>

							</div>
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="7" class="text-center text-muted py-4">
							No doctors found.
						</td>
					</tr>
				{% endfor %}
			</tbody>

		</table>
	</div>
	</div>
	<div class="d-flex justify-content-center mt-4">
		{{ knp_pagination_render(doctors) }}
	</div>
{% endblock %}
